# ─────────────────────────────────────────────────────────────
# AI FILTER — 환경 변수 예시
# 이 파일을 .env.local 로 복사해서 키를 채우면 실제 AI 분석이 켜집니다.
# 키가 없으면 목업(휴리스틱) 분석기로 자동 동작합니다.
# ─────────────────────────────────────────────────────────────

# OpenAI (텍스트/이미지 AI 생성 여부 판단). 없으면 목업 사용.
OPENAI_API_KEY=

# 사용할 모델 (기본: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Sightengine (이미지 딥페이크/AI 생성 탐지, 선택). 없으면 목업 사용.
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
